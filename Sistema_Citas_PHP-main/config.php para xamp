<?php

define('DB_SERVER', 'localhost');
define('DB_USERNAME', 'root');
define('DB_PASSWORD', '');  
define('DB_NAME', 'citas_medicas');

$conn = new mysqli(DB_SERVER, DB_USERNAME, DB_PASSWORD, DB_NAME);

if ($conn->connect_error) {
    die("Error de conexión: " . $conn->connect_error);
}

// Es mejor usar utf8mb4 en vez de utf8
$conn->set_charset("utf8mb4");

// Esta función solo normaliza texto y evita fallas en charset
function normalizar_texto($texto) {
    if (!is_string($texto) || $texto === '') {
        return $texto;
    }

    // Corrige problema como "MarÃ­a" -> "María"
    if (strpos($texto, 'Ã') !== false || strpos($texto, 'Â') !== false) {
        if (function_exists('mb_convert_encoding')) {
            return mb_convert_encoding($texto, 'UTF-8', 'ISO-8859-1');
        }
        if (function_exists('iconv')) {
            $convertido = @iconv('ISO-8859-1', 'UTF-8//IGNORE', $texto);
            if ($convertido !== false) {
                return $convertido;
            }
        }
    }

    return $texto;
}

